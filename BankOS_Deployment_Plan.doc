sudo chown -R www-data:www-data storage bootstrap/cache
sudo chmod -R 775 storage bootstrap/cache
</pre>

<!-- PHASE 6 -->
<div class="page-break"></div>
<h1 id="phase6">7. Phase 6 &mdash; Nginx Configuration</h1>

<h3>6.1 bankos Admin</h3>
<pre>
sudo nano /etc/nginx/sites-available/bankos-admin
</pre>

<p>Paste:</p>
<pre>
server {
    listen 80;
    server_name admin.yourdomain.com;
    root /var/www/bankos/public;
    index index.php;

    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";

    charset utf-8;
    client_max_body_size 50M;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }

    error_page 404 /index.php;

    location ~ \.php$ {
        fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
</pre>

<h3>6.2 bankos Portal</h3>
<pre>
sudo nano /etc/nginx/sites-available/bankos-portal
</pre>

<p>Paste (same structure, different server_name and root):</p>
<pre>
server {
    listen 80;
    server_name app.yourdomain.com;
    root /var/www/bankos-portal/public;
    index index.php;

    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";

    charset utf-8;
    client_max_body_size 50M;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }

    error_page 404 /index.php;

    location ~ \.php$ {
        fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
</pre>

<h3>6.3 bankos SuperAdmin</h3>
<pre>
sudo nano /etc/nginx/sites-available/bankos-superadmin
</pre>

<pre>
server {
    listen 80;
    server_name super.yourdomain.com;
    root /var/www/bankos-superadmin/public;
    index index.php;

    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";

    charset utf-8;
    client_max_body_size 50M;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }

    error_page 404 /index.php;

    location ~ \.php$ {
        fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
</pre>

<h3>6.4 Enable all sites</h3>
<pre>
sudo ln -s /etc/nginx/sites-available/bankos-admin /etc/nginx/sites-enabled/
sudo ln -s /etc/nginx/sites-available/bankos-portal /etc/nginx/sites-enabled/
sudo ln -s /etc/nginx/sites-available/bankos-superadmin /etc/nginx/sites-enabled/
sudo rm /etc/nginx/sites-enabled/default
sudo nginx -t
sudo systemctl reload nginx
</pre>

<!-- PHASE 7 -->
<div class="page-break"></div>
<h1 id="phase7">8. Phase 7 &mdash; SSL Certificates (Free HTTPS)</h1>

<h3>7.1 Point your domain first</h3>
<p>Go to your domain registrar and add these <strong>A records</strong>:</p>

<table>
    <tr><th>Type</th><th>Name</th><th>Value</th></tr>
    <tr><td>A</td><td>admin</td><td>YOUR_SERVER_IP</td></tr>
    <tr><td>A</td><td>app</td><td>YOUR_SERVER_IP</td></tr>
    <tr><td>A</td><td>super</td><td>YOUR_SERVER_IP</td></tr>
</table>

<p>Wait 5-10 minutes for DNS to propagate.</p>

<h3>7.2 Install SSL</h3>
<pre>
sudo apt install -y certbot python3-certbot-nginx

sudo certbot --nginx \
  -d admin.yourdomain.com \
  -d app.yourdomain.com \
  -d super.yourdomain.com \
  --non-interactive \
  --agree-tos \
  -m your@email.com
</pre>

<div class="note">
    <strong>Note:</strong> Certbot auto-renews every 90 days &mdash; nothing else to do.
</div>

<!-- PHASE 8 -->
<h1 id="phase8">9. Phase 8 &mdash; Queue Workers (Supervisor)</h1>

<pre>
sudo nano /etc/supervisor/conf.d/bankos.conf
</pre>

<p>Paste:</p>
<pre>
[program:bankos-admin-worker]
process_name=%(program_name)s_%(process_num)02d
command=php /var/www/bankos/artisan queue:work redis --sleep=3 --tries=3 --max-time=3600
autostart=true
autorestart=true
user=www-data
numprocs=2
redirect_stderr=true
stdout_logfile=/var/log/bankos-admin-worker.log

[program:bankos-portal-worker]
process_name=%(program_name)s_%(process_num)02d
command=php /var/www/bankos-portal/artisan queue:work redis --sleep=3 --tries=3 --max-time=3600
autostart=true
autorestart=true
user=www-data
numprocs=1
redirect_stderr=true
stdout_logfile=/var/log/bankos-portal-worker.log
</pre>

<pre>
sudo supervisorctl reread
sudo supervisorctl update
sudo supervisorctl status
</pre>

<p>You should see the workers running.</p>

<!-- PHASE 9 -->
<div class="page-break"></div>
<h1 id="phase9">10. Phase 9 &mdash; Database Migration</h1>

<h3>Option A: Export from local PostgreSQL and import</h3>

<h4>On your local Windows machine (in Laragon terminal):</h4>
<pre>
pg_dump -U postgres -h 127.0.0.1 -d bankos -F c -f bankos_backup.dump
</pre>

<p>Upload <code>bankos_backup.dump</code> to the server using FileZilla (put it in <code>/home/deploy/</code>).</p>

<h4>On the server:</h4>
<pre>
sudo -u postgres pg_restore -d bankos -c --if-exists /home/deploy/bankos_backup.dump
</pre>

<h3>Option B: Fresh database (run migrations + seeders)</h3>
<pre>
cd /var/www/bankos
php artisan migrate --force
php artisan db:seed --force
</pre>

<!-- PHASE 10 -->
<div class="page-break"></div>
<h1 id="phase10">11. Phase 10 &mdash; Continuous Deployment</h1>

<h3>10.1 Create deploy script on server</h3>
<pre>
nano /home/deploy/deploy-bankos.sh
</pre>

<p>Paste:</p>
<pre>
#!/bin/bash
set -e

echo "==============================="
echo "Deploying bankOS Admin..."
echo "==============================="
cd /var/www/bankos
git pull origin main
composer install --no-dev --optimize-autoloader
php artisan migrate --force
php artisan config:cache
php artisan route:cache
php artisan view:clear
npm ci &amp;&amp; npm run build
sudo supervisorctl restart bankos-admin-worker:*

echo "==============================="
echo "Deploying bankOS Portal..."
echo "==============================="
cd /var/www/bankos-portal
git pull origin main
composer install --no-dev --optimize-autoloader
php artisan migrate --force
php artisan config:cache
php artisan route:cache
php artisan view:clear
npm ci &amp;&amp; npm run build
sudo supervisorctl restart bankos-portal-worker:*

echo "==============================="
echo "Deploying bankOS SuperAdmin..."
echo "==============================="
cd /var/www/bankos-superadmin
git pull origin main
composer install --no-dev --optimize-autoloader
php artisan migrate --force
php artisan config:cache
php artisan route:cache
php artisan view:clear

echo "==============================="
echo "ALL DEPLOYMENTS COMPLETE!"
echo "==============================="
</pre>

<pre>
chmod +x /home/deploy/deploy-bankos.sh
</pre>

<h3>10.2 How to deploy updates</h3>

<p>Every time you push code changes locally:</p>

<h4>Step 1: Push from your local machine</h4>
<pre>
cd "c:/laragon/www/antigravity codes/bankos"
git add .
git commit -m "your changes"
git push origin main
</pre>

<h4>Step 2: SSH into server and deploy</h4>
<pre>
ssh deploy@YOUR_SERVER_IP
bash /home/deploy/deploy-bankos.sh
</pre>

<p>That's it &mdash; your site is updated.</p>

<h3>10.3 (Optional) Auto-deploy with GitHub Actions</h3>
<p>If you want <strong>zero SSH</strong> after pushing, add this file to each repo at <code>.github/workflows/deploy.yml</code>:</p>

<pre>
name: Deploy

on:
  push:
    branches: [main]

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Deploy via SSH
        uses: appleboy/ssh-action@v1
        with:
          host: ${{ secrets.SERVER_IP }}
          username: deploy
          password: ${{ secrets.SERVER_PASSWORD }}
          script: bash /home/deploy/deploy-bankos.sh
</pre>

<p>Add in each GitHub repo &rarr; <strong>Settings &rarr; Secrets &rarr; Actions</strong>:</p>
<ul>
    <li><code>SERVER_IP</code> = your Hetzner IP</li>
    <li><code>SERVER_PASSWORD</code> = your deploy user's password</li>
</ul>

<div class="note">
    <strong>Result:</strong> Now every <code>git push</code> auto-deploys. No SSH needed.
</div>

<!-- PHASE 11 -->
<div class="page-break"></div>
<h1 id="phase11">12. Phase 11 &mdash; Database Backups</h1>

<div class="important">
    <strong>Critical for a banking application!</strong> Never run without automated backups.
</div>

<h3>11.1 Automated daily backups</h3>
<pre>
sudo mkdir -p /var/backups/bankos
sudo chown deploy:deploy /var/backups/bankos

nano /home/deploy/backup-db.sh
</pre>

<p>Paste:</p>
<pre>
#!/bin/bash
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_DIR="/var/backups/bankos"
KEEP_DAYS=30

# Create backup
sudo -u postgres pg_dump -F c bankos > "$BACKUP_DIR/bankos_$TIMESTAMP.dump"

# Delete backups older than 30 days
find $BACKUP_DIR -name "*.dump" -mtime +$KEEP_DAYS -delete

echo "Backup complete: bankos_$TIMESTAMP.dump"
</pre>

<pre>
chmod +x /home/deploy/backup-db.sh
</pre>

<h3>11.2 Schedule it (runs every day at 2 AM)</h3>
<pre>
crontab -e
</pre>

<p>Add this line:</p>
<pre>
0 2 * * * /home/deploy/backup-db.sh >> /var/log/bankos-backup.log 2>&amp;1
</pre>

